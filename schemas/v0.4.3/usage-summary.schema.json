{
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/usage-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "0.3.1"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "cost_basis_ids"
              ]
            },
            {
              "required": [
                "pricing_snapshot_ids"
              ]
            },
            {
              "required": [
                "pricing_snapshot_digests"
              ]
            },
            {
              "required": [
                "cost_observation_count"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "estimated_cost_microusd": {
            "type": "integer"
          }
        },
        "required": [
          "estimated_cost_microusd"
        ]
      },
      "then": {
        "properties": {
          "currency": {
            "const": "USD"
          }
        }
      }
    }
  ],
  "properties": {
    "artifact_kind": {
      "const": "usage-summary",
      "default": "usage-summary",
      "title": "Artifact Kind",
      "type": "string"
    },
    "cost_basis_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Cost Basis Ids",
      "type": "array"
    },
    "cost_observation_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Observation Count"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "estimated_cost_microusd": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Cost Microusd"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "pricing_snapshot_digests": {
      "default": [],
      "items": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "title": "Pricing Snapshot Digests",
      "type": "array"
    },
    "pricing_snapshot_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Pricing Snapshot Ids",
      "type": "array"
    },
    "schema_version": {
      "default": "0.4.3",
      "enum": [
        "0.3.1",
        "0.4.3"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "total_latency_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Latency Ms"
    },
    "total_retries": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Retries"
    },
    "total_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tokens"
    },
    "total_tool_calls": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tool Calls"
    }
  },
  "title": "UsageSummary",
  "type": "object"
}
