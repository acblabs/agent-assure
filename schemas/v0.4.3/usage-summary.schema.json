{
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/usage-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "usage-summary",
      "default": "usage-summary",
      "title": "Artifact Kind",
      "type": "string"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "estimated_cost_microusd": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Cost Microusd"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "schema_version": {
      "const": "0.3.1",
      "default": "0.3.1",
      "title": "Schema Version",
      "type": "string"
    },
    "total_latency_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Latency Ms"
    },
    "total_retries": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Retries"
    },
    "total_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tokens"
    },
    "total_tool_calls": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tool Calls"
    }
  },
  "title": "UsageSummary",
  "type": "object"
}
