{
  "$defs": {
    "EnvironmentInfo": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "environment-info",
          "default": "environment-info",
          "title": "Artifact Kind",
          "type": "string"
        },
        "dependency_inventory_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Digest"
        },
        "dependency_inventory_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Path"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Commit"
        },
        "git_dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Dirty"
        },
        "installed_packages": {
          "default": [],
          "items": {
            "$ref": "#/$defs/InstalledPackage"
          },
          "title": "Installed Packages",
          "type": "array"
        },
        "lockfile_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Digest"
        },
        "lockfile_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Path"
        },
        "platform": {
          "title": "Platform",
          "type": "string"
        },
        "python_version": {
          "title": "Python Version",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "platform",
        "python_version"
      ],
      "title": "EnvironmentInfo",
      "type": "object"
    },
    "InstalledPackage": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "installed-package",
          "default": "installed-package",
          "title": "Artifact Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "InstalledPackage",
      "type": "object"
    },
    "ReleaseArtifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "release-artifact",
          "default": "release-artifact",
          "title": "Artifact Kind",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "role",
        "path",
        "sha256"
      ],
      "title": "ReleaseArtifact",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/release-artifact-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "release-artifact-manifest",
      "default": "release-artifact-manifest",
      "title": "Artifact Kind",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ReleaseArtifact"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "environment": {
      "$ref": "#/$defs/EnvironmentInfo"
    },
    "limitations": {
      "default": [
        "release artifact manifests record deterministic file digests only; they are not signatures or attestations"
      ],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "manifest_id": {
      "title": "Manifest Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.4.3",
      "enum": [
        "0.2.0",
        "0.3.1",
        "0.4.3"
      ],
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "manifest_id",
    "artifacts",
    "environment"
  ],
  "title": "ReleaseArtifactManifest",
  "type": "object"
}
