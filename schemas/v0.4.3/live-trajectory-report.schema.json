{
  "$defs": {
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "HistoryDependentTrajectoryCheck": {
      "additionalProperties": false,
      "properties": {
        "affected_observation_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Affected Observation Ids",
          "type": "array"
        },
        "affected_observations": {
          "minimum": 0,
          "title": "Affected Observations",
          "type": "integer"
        },
        "artifact_kind": {
          "const": "history-dependent-trajectory-check",
          "default": "history-dependent-trajectory-check",
          "title": "Artifact Kind",
          "type": "string"
        },
        "check_id": {
          "minLength": 1,
          "title": "Check Id",
          "type": "string"
        },
        "dependency": {
          "minLength": 1,
          "title": "Dependency",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "dependency",
        "prerequisite_status",
        "affected_observations"
      ],
      "title": "HistoryDependentTrajectoryCheck",
      "type": "object"
    },
    "OperationalEventProcessSummary": {
      "additionalProperties": false,
      "properties": {
        "analysis_method": {
          "enum": [
            "poisson_rate",
            "renewal_gap_summary",
            "burst_window_count"
          ],
          "title": "Analysis Method",
          "type": "string"
        },
        "artifact_kind": {
          "const": "operational-event-process-summary",
          "default": "operational-event-process-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "burst_signal": {
          "default": "none",
          "enum": [
            "none",
            "review",
            "invalid"
          ],
          "title": "Burst Signal",
          "type": "string"
        },
        "burst_window_seconds": {
          "minimum": 1,
          "title": "Burst Window Seconds",
          "type": "integer"
        },
        "event_rate": {
          "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
          "title": "Event Rate",
          "type": "string"
        },
        "event_type": {
          "enum": [
            "retry",
            "rate_limit",
            "exclusion",
            "runtime_failure",
            "malformed_output",
            "emergency_process",
            "budget_stop"
          ],
          "title": "Event Type",
          "type": "string"
        },
        "exposure": {
          "minimum": 0,
          "title": "Exposure",
          "type": "integer"
        },
        "exposure_unit": {
          "default": "observation",
          "minLength": 1,
          "title": "Exposure Unit",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "max_events_in_burst_window": {
          "minimum": 0,
          "title": "Max Events In Burst Window",
          "type": "integer"
        },
        "mean_interarrival_seconds": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Interarrival Seconds"
        },
        "missing_timestamp_events": {
          "minimum": 0,
          "title": "Missing Timestamp Events",
          "type": "integer"
        },
        "observation_window_seconds": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Window Seconds"
        },
        "observed_events": {
          "minimum": 0,
          "title": "Observed Events",
          "type": "integer"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "timestamped_events": {
          "minimum": 0,
          "title": "Timestamped Events",
          "type": "integer"
        }
      },
      "required": [
        "event_type",
        "observed_events",
        "exposure",
        "event_rate",
        "analysis_method",
        "prerequisite_status",
        "timestamped_events",
        "missing_timestamp_events",
        "max_events_in_burst_window",
        "burst_window_seconds"
      ],
      "title": "OperationalEventProcessSummary",
      "type": "object"
    },
    "TrajectoryInvariantResult": {
      "additionalProperties": false,
      "properties": {
        "affected_observation_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Affected Observation Ids",
          "type": "array"
        },
        "affected_observations": {
          "minimum": 0,
          "title": "Affected Observations",
          "type": "integer"
        },
        "artifact_kind": {
          "const": "trajectory-invariant-result",
          "default": "trajectory-invariant-result",
          "title": "Artifact Kind",
          "type": "string"
        },
        "category": {
          "enum": [
            "governance_control_failure",
            "operational_reliability_warning"
          ],
          "title": "Category",
          "type": "string"
        },
        "evaluated_observations": {
          "minimum": 0,
          "title": "Evaluated Observations",
          "type": "integer"
        },
        "interpretation": {
          "enum": [
            "exploratory",
            "confirmatory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "invariant_id": {
          "minLength": 1,
          "title": "Invariant Id",
          "type": "string"
        },
        "invariant_type": {
          "enum": [
            "forbidden_state",
            "required_review_for_approval",
            "claim_evidence_before_approval",
            "attempt_retry_consistency"
          ],
          "title": "Invariant Type",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState",
          "default": "not_evaluated"
        }
      },
      "required": [
        "invariant_id",
        "label",
        "invariant_type",
        "category",
        "interpretation",
        "prerequisite_status",
        "affected_observations",
        "evaluated_observations"
      ],
      "title": "TrajectoryInvariantResult",
      "type": "object"
    },
    "TrajectoryPathSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "trajectory-path-summary",
          "default": "trajectory-path-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "minLength": 1,
          "title": "Case Id",
          "type": "string"
        },
        "claim_count": {
          "minimum": 0,
          "title": "Claim Count",
          "type": "integer"
        },
        "claim_evidence_link_count": {
          "minimum": 0,
          "title": "Claim Evidence Link Count",
          "type": "integer"
        },
        "cluster_id": {
          "minLength": 1,
          "title": "Cluster Id",
          "type": "string"
        },
        "evidence_ref_count": {
          "minimum": 0,
          "title": "Evidence Ref Count",
          "type": "integer"
        },
        "has_ordered_timestamps": {
          "default": false,
          "title": "Has Ordered Timestamps",
          "type": "boolean"
        },
        "human_review_performed": {
          "default": false,
          "title": "Human Review Performed",
          "type": "boolean"
        },
        "human_review_required": {
          "default": false,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "policy_result_count": {
          "minimum": 0,
          "title": "Policy Result Count",
          "type": "integer"
        },
        "repetition_index": {
          "minimum": 0,
          "title": "Repetition Index",
          "type": "integer"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "states": {
          "items": {
            "enum": [
              "start",
              "request_assembly",
              "provider_call",
              "tool_call",
              "evidence_check",
              "policy_check",
              "redaction_check",
              "human_review",
              "verdict",
              "excluded",
              "emergency"
            ],
            "type": "string"
          },
          "minItems": 2,
          "title": "States",
          "type": "array"
        },
        "terminal_state": {
          "enum": [
            "start",
            "request_assembly",
            "provider_call",
            "tool_call",
            "evidence_check",
            "policy_check",
            "redaction_check",
            "human_review",
            "verdict",
            "excluded",
            "emergency"
          ],
          "title": "Terminal State",
          "type": "string"
        },
        "tool_count": {
          "minimum": 0,
          "title": "Tool Count",
          "type": "integer"
        },
        "transition_count": {
          "minimum": 1,
          "title": "Transition Count",
          "type": "integer"
        }
      },
      "required": [
        "observation_id",
        "run_id",
        "case_id",
        "repetition_index",
        "cluster_id",
        "terminal_state",
        "states",
        "transition_count",
        "tool_count",
        "claim_count",
        "evidence_ref_count",
        "claim_evidence_link_count",
        "policy_result_count"
      ],
      "title": "TrajectoryPathSummary",
      "type": "object"
    },
    "TrajectoryTransitionSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "trajectory-transition-summary",
          "default": "trajectory-transition-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "conditional_frequency": {
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "title": "Conditional Frequency",
          "type": "string"
        },
        "count": {
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "from_state": {
          "enum": [
            "start",
            "request_assembly",
            "provider_call",
            "tool_call",
            "evidence_check",
            "policy_check",
            "redaction_check",
            "human_review",
            "verdict",
            "excluded",
            "emergency"
          ],
          "title": "From State",
          "type": "string"
        },
        "from_state_count": {
          "minimum": 0,
          "title": "From State Count",
          "type": "integer"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "to_state": {
          "enum": [
            "start",
            "request_assembly",
            "provider_call",
            "tool_call",
            "evidence_check",
            "policy_check",
            "redaction_check",
            "human_review",
            "verdict",
            "excluded",
            "emergency"
          ],
          "title": "To State",
          "type": "string"
        }
      },
      "required": [
        "from_state",
        "to_state",
        "count",
        "from_state_count",
        "conditional_frequency",
        "prerequisite_status"
      ],
      "title": "TrajectoryTransitionSummary",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/live-trajectory-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "live-trajectory-report",
      "default": "live-trajectory-report",
      "title": "Artifact Kind",
      "type": "string"
    },
    "evaluation_report_id": {
      "minLength": 1,
      "title": "Evaluation Report Id",
      "type": "string"
    },
    "event_processes": {
      "items": {
        "$ref": "#/$defs/OperationalEventProcessSummary"
      },
      "title": "Event Processes",
      "type": "array"
    },
    "excluded_observations": {
      "minimum": 0,
      "title": "Excluded Observations",
      "type": "integer"
    },
    "history_dependent_checks": {
      "items": {
        "$ref": "#/$defs/HistoryDependentTrajectoryCheck"
      },
      "title": "History Dependent Checks",
      "type": "array"
    },
    "included_observations": {
      "minimum": 0,
      "title": "Included Observations",
      "type": "integer"
    },
    "interpretation": {
      "default": "exploratory",
      "enum": [
        "exploratory",
        "confirmatory"
      ],
      "title": "Interpretation",
      "type": "string"
    },
    "invariants": {
      "items": {
        "$ref": "#/$defs/TrajectoryInvariantResult"
      },
      "title": "Invariants",
      "type": "array"
    },
    "limitations": {
      "default": [
        "trajectory analysis is derived from privacy-filtered structured artifacts",
        "trajectory and event-process outputs are review signals and are not release-verdict gates",
        "path coverage over observed records is not proof that unsafe paths are impossible"
      ],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "observations": {
      "minimum": 0,
      "title": "Observations",
      "type": "integer"
    },
    "paths": {
      "items": {
        "$ref": "#/$defs/TrajectoryPathSummary"
      },
      "title": "Paths",
      "type": "array"
    },
    "protocol_digest": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Protocol Digest"
    },
    "protocol_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Protocol Id"
    },
    "report_id": {
      "minLength": 1,
      "title": "Report Id",
      "type": "string"
    },
    "runset_id": {
      "minLength": 1,
      "title": "Runset Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.4.3",
      "enum": [
        "0.2.0",
        "0.3.1",
        "0.4.3"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/GateState",
      "default": "not_evaluated"
    },
    "suite_id": {
      "minLength": 1,
      "title": "Suite Id",
      "type": "string"
    },
    "suite_version": {
      "minLength": 1,
      "title": "Suite Version",
      "type": "string"
    },
    "trajectory_plan_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trajectory Plan Id"
    },
    "trajectory_status": {
      "enum": [
        "valid",
        "exploratory",
        "invalid"
      ],
      "title": "Trajectory Status",
      "type": "string"
    },
    "transition_assumption": {
      "const": "canonical_observable_order",
      "default": "canonical_observable_order",
      "title": "Transition Assumption",
      "type": "string"
    },
    "transition_assumption_status": {
      "enum": [
        "met",
        "exploratory",
        "invalid"
      ],
      "title": "Transition Assumption Status",
      "type": "string"
    },
    "transitions": {
      "items": {
        "$ref": "#/$defs/TrajectoryTransitionSummary"
      },
      "title": "Transitions",
      "type": "array"
    }
  },
  "required": [
    "report_id",
    "runset_id",
    "evaluation_report_id",
    "suite_id",
    "suite_version",
    "trajectory_status",
    "transition_assumption_status",
    "observations",
    "included_observations",
    "excluded_observations",
    "paths",
    "transitions",
    "invariants",
    "history_dependent_checks",
    "event_processes"
  ],
  "title": "LiveTrajectoryReport",
  "type": "object"
}
