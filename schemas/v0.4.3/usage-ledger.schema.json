{
  "$comment": "Pydantic validation verifies that missingness equals the counts derived from segments. JSON Schema validates shape and non-negative counts.",
  "$defs": {
    "UsageSegment": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "limitations": {
                "minItems": 1
              }
            },
            "required": [
              "limitations"
            ]
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-segment",
          "default": "usage-segment",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cached_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Tokens"
        },
        "case_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "completion_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completion Tokens"
        },
        "cost_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "event_range_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range End"
        },
        "event_range_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range Start"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "operation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operation"
        },
        "parent_span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Span Id"
        },
        "pricing_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricing Snapshot Id"
        },
        "prompt_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Tokens"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "retry_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Count"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "schema_version": {
          "const": "0.3.1",
          "default": "0.3.1",
          "title": "Schema Version",
          "type": "string"
        },
        "segment_id": {
          "minLength": 1,
          "title": "Segment Id",
          "type": "string"
        },
        "span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Id"
        },
        "tool_call_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Count"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "required": [
        "segment_id"
      ],
      "title": "UsageSegment",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/usage-ledger.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "aggregation_method": {
      "const": "sum_known_fields_v1",
      "default": "sum_known_fields_v1",
      "title": "Aggregation Method",
      "type": "string"
    },
    "artifact_kind": {
      "const": "usage-ledger",
      "default": "usage-ledger",
      "title": "Artifact Kind",
      "type": "string"
    },
    "missingness": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "description": "Counts of segment fields that were missing during aggregation; Pydantic validation requires this to match the contributing segments.",
      "title": "Missingness",
      "type": "object"
    },
    "schema_version": {
      "const": "0.3.1",
      "default": "0.3.1",
      "title": "Schema Version",
      "type": "string"
    },
    "segments": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UsageSegment"
      },
      "title": "Segments",
      "type": "array"
    }
  },
  "title": "UsageLedger",
  "type": "object"
}
