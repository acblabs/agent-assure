{
  "$defs": {
    "ClaimEvidenceLink": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "claim-evidence-link",
          "default": "claim-evidence-link",
          "title": "Artifact Kind",
          "type": "string"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "evidence_ref_id": {
          "title": "Evidence Ref Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "evidence_ref_id"
      ],
      "title": "ClaimEvidenceLink",
      "type": "object"
    },
    "ClaimRecord": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "claim-record",
          "default": "claim-record",
          "title": "Artifact Kind",
          "type": "string"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "claim_id"
      ],
      "title": "ClaimRecord",
      "type": "object"
    },
    "EvidenceItem": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "evidence-item",
          "default": "evidence-item",
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_digest": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Digest",
          "type": "string"
        },
        "ref_id": {
          "title": "Ref Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "source_id",
        "content_digest"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "evidence-ref",
          "default": "evidence-ref",
          "title": "Artifact Kind",
          "type": "string"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Claim Ids",
          "type": "array"
        },
        "ref_id": {
          "title": "Ref Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "source_id"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "ExecutionMode": {
      "enum": [
        "fixture",
        "live"
      ],
      "title": "ExecutionMode",
      "type": "string"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "PolicyResult": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "policy-result",
          "default": "policy-result",
          "title": "Artifact Kind",
          "type": "string"
        },
        "gate_profile": {
          "default": "default",
          "title": "Gate Profile",
          "type": "string"
        },
        "message": {
          "default": "",
          "title": "Message",
          "type": "string"
        },
        "policy_id": {
          "title": "Policy Id",
          "type": "string"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "info"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "policy_id",
        "state"
      ],
      "title": "PolicyResult",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "provenance",
          "default": "provenance",
          "title": "Artifact Kind",
          "type": "string"
        },
        "code_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Digest"
        },
        "configuration_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Configuration Digest"
        },
        "fixture_manifest_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixture Manifest Digest"
        },
        "model_identifier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Identifier"
        },
        "policy_bundle_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Policy Bundle Digest"
        },
        "prompt_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Digest"
        },
        "retrieval_corpus_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieval Corpus Digest"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "tool_schema_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Schema Digest"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "blocker"
      ],
      "title": "Severity",
      "type": "string"
    },
    "UsageLedger": {
      "$comment": "Pydantic validation verifies that missingness equals the counts derived from segments. JSON Schema validates shape and non-negative counts.",
      "additionalProperties": false,
      "properties": {
        "aggregation_method": {
          "const": "sum_known_fields_v1",
          "default": "sum_known_fields_v1",
          "title": "Aggregation Method",
          "type": "string"
        },
        "artifact_kind": {
          "const": "usage-ledger",
          "default": "usage-ledger",
          "title": "Artifact Kind",
          "type": "string"
        },
        "missingness": {
          "additionalProperties": {
            "minimum": 0,
            "type": "integer"
          },
          "description": "Counts of segment fields that were missing during aggregation; Pydantic validation requires this to match the contributing segments.",
          "title": "Missingness",
          "type": "object"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "segments": {
          "default": [],
          "items": {
            "$ref": "#/$defs/UsageSegment"
          },
          "title": "Segments",
          "type": "array"
        }
      },
      "title": "UsageLedger",
      "type": "object"
    },
    "UsageSegment": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "pricing_snapshot_digest"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              },
              "limitations": {
                "minItems": 1
              }
            },
            "required": [
              "limitations"
            ]
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-segment",
          "default": "usage-segment",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cached_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Tokens"
        },
        "case_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "completion_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completion Tokens"
        },
        "cost_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "event_range_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range End"
        },
        "event_range_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range Start"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "operation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operation"
        },
        "parent_span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Span Id"
        },
        "pricing_snapshot_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricing Snapshot Digest"
        },
        "pricing_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricing Snapshot Id"
        },
        "prompt_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Tokens"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "retry_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Count"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "segment_id": {
          "minLength": 1,
          "title": "Segment Id",
          "type": "string"
        },
        "span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Id"
        },
        "tool_call_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Count"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "required": [
        "segment_id"
      ],
      "title": "UsageSegment",
      "type": "object"
    },
    "UsageSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "cost_basis_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_digests"
                  ]
                },
                {
                  "required": [
                    "cost_observation_count"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-summary",
          "default": "usage-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cost_basis_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Cost Basis Ids",
          "type": "array"
        },
        "cost_observation_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Observation Count"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "pricing_snapshot_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Pricing Snapshot Digests",
          "type": "array"
        },
        "pricing_snapshot_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Pricing Snapshot Ids",
          "type": "array"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "total_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Latency Ms"
        },
        "total_retries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Retries"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        },
        "total_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tool Calls"
        }
      },
      "title": "UsageSummary",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.4.3/agent-run-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "0.2.0"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "usage_ledger"
              ]
            },
            {
              "required": [
                "usage_summary"
              ]
            }
          ]
        }
      }
    }
  ],
  "properties": {
    "adapter_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Adapter Id"
    },
    "artifact_kind": {
      "const": "agent-run-record",
      "default": "agent-run-record",
      "title": "Artifact Kind",
      "type": "string"
    },
    "attempt_count": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attempt Count"
    },
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "claim_evidence_links": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ClaimEvidenceLink"
      },
      "title": "Claim Evidence Links",
      "type": "array"
    },
    "claims": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ClaimRecord"
      },
      "title": "Claims",
      "type": "array"
    },
    "cluster_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cluster Id"
    },
    "completed_at_utc": {
