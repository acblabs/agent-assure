{
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.5.0/usage-summary-delta.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "0.3.1"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "total_tokens_delta_bps"
              ]
            },
            {
              "required": [
                "total_tool_calls_delta_bps"
              ]
            },
            {
              "required": [
                "total_retries_delta_bps"
              ]
            },
            {
              "required": [
                "total_latency_ms_delta_bps"
              ]
            },
            {
              "required": [
                "estimated_cost_microusd_delta_bps"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "estimated_cost_microusd_delta": {
            "type": "integer"
          }
        },
        "required": [
          "estimated_cost_microusd_delta"
        ]
      },
      "then": {
        "properties": {
          "currency": {
            "const": "USD"
          }
        }
      }
    }
  ],
  "properties": {
    "artifact_kind": {
      "const": "usage-summary-delta",
      "default": "usage-summary-delta",
      "title": "Artifact Kind",
      "type": "string"
    },
    "baseline_observed": {
      "title": "Baseline Observed",
      "type": "boolean"
    },
    "candidate_observed": {
      "title": "Candidate Observed",
      "type": "boolean"
    },
    "comparison_state": {
      "enum": [
        "observed",
        "not_observed",
        "baseline_not_observed",
        "candidate_not_observed"
      ],
      "title": "Comparison State",
      "type": "string"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "estimated_cost_microusd_delta": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Cost Microusd Delta"
    },
    "estimated_cost_microusd_delta_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Estimated Cost Microusd Delta Bps"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "schema_version": {
      "default": "0.4.3",
      "enum": [
        "0.3.1",
        "0.4.3"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "total_latency_ms_delta": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Latency Ms Delta"
    },
    "total_latency_ms_delta_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Latency Ms Delta Bps"
    },
    "total_retries_delta": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Retries Delta"
    },
    "total_retries_delta_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Retries Delta Bps"
    },
    "total_tokens_delta": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tokens Delta"
    },
    "total_tokens_delta_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tokens Delta Bps"
    },
    "total_tool_calls_delta": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tool Calls Delta"
    },
    "total_tool_calls_delta_bps": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Tool Calls Delta Bps"
    }
  },
  "required": [
    "comparison_state",
    "baseline_observed",
    "candidate_observed"
  ],
  "title": "UsageSummaryDelta",
  "type": "object"
}
