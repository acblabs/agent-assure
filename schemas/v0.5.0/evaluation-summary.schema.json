{
  "$defs": {
    "EnvironmentInfo": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "environment-info",
          "default": "environment-info",
          "title": "Artifact Kind",
          "type": "string"
        },
        "dependency_inventory_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Digest"
        },
        "dependency_inventory_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Path"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Commit"
        },
        "git_dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Dirty"
        },
        "installed_packages": {
          "default": [],
          "items": {
            "$ref": "#/$defs/InstalledPackage"
          },
          "title": "Installed Packages",
          "type": "array"
        },
        "lockfile_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Digest"
        },
        "lockfile_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Path"
        },
        "platform": {
          "title": "Platform",
          "type": "string"
        },
        "python_version": {
          "title": "Python Version",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "platform",
        "python_version"
      ],
      "title": "EnvironmentInfo",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "finding",
          "default": "finding",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "control_id": {
          "default": "",
          "title": "Control Id",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        },
        "target": {
          "default": "",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "case_id",
        "state",
        "reason_code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "InstalledPackage": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "installed-package",
          "default": "installed-package",
          "title": "Artifact Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "InstalledPackage",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "UsageSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "cost_basis_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_digests"
                  ]
                },
                {
                  "required": [
                    "cost_observation_count"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-summary",
          "default": "usage-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cost_basis_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Cost Basis Ids",
          "type": "array"
        },
        "cost_observation_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Observation Count"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "pricing_snapshot_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Pricing Snapshot Digests",
          "type": "array"
        },
        "pricing_snapshot_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Pricing Snapshot Ids",
          "type": "array"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "total_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Latency Ms"
        },
        "total_retries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Retries"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        },
        "total_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tool Calls"
        }
      },
      "title": "UsageSummary",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.5.0/evaluation-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "0.2.0"
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "usage_summary"
              ]
            }
          ]
        }
      }
    }
  ],
  "properties": {
    "artifact_kind": {
      "const": "evaluation-summary",
      "default": "evaluation-summary",
      "title": "Artifact Kind",
      "type": "string"
    },
    "environment": {
      "anyOf": [
        {
          "$ref": "#/$defs/EnvironmentInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "runset_id": {
      "title": "Runset Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.5.0",
      "enum": [
        "0.2.0",
        "0.3.1",
        "0.4.3",
        "0.5.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/GateState"
    },
    "usage_summary": {
      "anyOf": [
        {
          "$ref": "#/$defs/UsageSummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "runset_id",
    "state"
  ],
  "title": "EvaluationSummary",
  "type": "object"
}
