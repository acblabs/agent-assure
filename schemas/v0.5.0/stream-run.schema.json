{
  "$defs": {
    "FrameworkObservation": {
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "event_type": {
          "minLength": 1,
          "title": "Event Type",
          "type": "string"
        },
        "evidence_refs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "framework": {
          "minLength": 1,
          "title": "Framework",
          "type": "string"
        },
        "framework_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Framework Version"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "node_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Node Id"
        },
        "node_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Node Name"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "privacy_filtered_attributes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Privacy Filtered Attributes",
          "type": "object"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "redaction_state": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redaction State"
        },
        "review_route": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Route"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "sequence_number": {
          "minimum": 0,
          "title": "Sequence Number",
          "type": "integer"
        },
        "span_context": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Context"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        },
        "tool_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Name"
        },
        "usage_segment": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "observation_id",
        "framework",
        "run_id",
        "sequence_number",
        "event_type"
      ],
      "title": "FrameworkObservation",
      "type": "object"
    },
    "StreamEventRecord": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "stream-event-record",
          "default": "stream-event-record",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "digest": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "event_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "event_type": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Event Type",
          "type": "string"
        },
        "node_id": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Node Id"
        },
        "observation": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrameworkObservation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "parent_span_id": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Span Id"
        },
        "privacy_filtered_attributes": {
          "additionalProperties": {
            "maxLength": 8192,
            "type": "string"
          },
          "propertyNames": {
            "maxLength": 512
          },
          "title": "Privacy Filtered Attributes",
          "type": "object"
        },
        "producer_id": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Producer Id"
        },
        "run_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "sequence_number": {
          "minimum": 0,
          "title": "Sequence Number",
          "type": "integer"
        },
        "span_id": {
          "anyOf": [
            {
              "maxLength": 512,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Id"
        },
        "timestamp": {
          "anyOf": [
            {
              "maxLength": 512,
              "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        },
        "traceparent": {
          "anyOf": [
            {
              "maxLength": 512,
              "pattern": "^00-[a-f0-9]{32}-[a-f0-9]{16}-[a-f0-9]{2}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Traceparent"
        },
        "usage_segment": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSegment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "event_id",
        "run_id",
        "sequence_number",
        "event_type",
        "digest"
      ],
      "title": "StreamEventRecord",
      "type": "object"
    },
    "StreamSequenceContract": {
      "additionalProperties": false,
      "properties": {
        "producer_field": {
          "anyOf": [
            {
              "enum": [
                "producer_id",
                "node_id",
                "span_id"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Producer Field"
        },
        "scope": {
          "enum": [
            "global",
            "producer_local"
          ],
          "title": "Scope",
          "type": "string"
        }
      },
      "required": [
        "scope"
      ],
      "title": "StreamSequenceContract",
      "type": "object"
    },
    "UsageLedger": {
      "$comment": "Pydantic validation verifies that missingness equals the counts derived from segments. JSON Schema validates shape and non-negative counts.",
      "additionalProperties": false,
      "properties": {
        "aggregation_method": {
          "const": "sum_known_fields_v1",
          "default": "sum_known_fields_v1",
          "title": "Aggregation Method",
          "type": "string"
        },
        "artifact_kind": {
          "const": "usage-ledger",
          "default": "usage-ledger",
          "title": "Artifact Kind",
          "type": "string"
        },
        "missingness": {
          "additionalProperties": {
            "minimum": 0,
            "type": "integer"
          },
          "description": "Counts of segment fields that were missing during aggregation; Pydantic validation requires this to match the contributing segments.",
          "title": "Missingness",
          "type": "object"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "segments": {
          "default": [],
          "items": {
            "$ref": "#/$defs/UsageSegment"
          },
          "title": "Segments",
          "type": "array"
        }
      },
      "title": "UsageLedger",
      "type": "object"
    },
    "UsageSegment": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "pricing_snapshot_digest"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              },
              "limitations": {
                "minItems": 1
              }
            },
            "required": [
              "limitations"
            ]
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-segment",
          "default": "usage-segment",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cached_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Tokens"
        },
        "case_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "completion_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completion Tokens"
        },
        "cost_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Basis"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "event_range_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range End"
        },
        "event_range_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Range Start"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "operation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operation"
        },
        "parent_span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Span Id"
        },
        "pricing_snapshot_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricing Snapshot Digest"
        },
        "pricing_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pricing Snapshot Id"
        },
        "prompt_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Tokens"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "retry_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Count"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "segment_id": {
          "minLength": 1,
          "title": "Segment Id",
          "type": "string"
        },
        "span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Span Id"
        },
        "tool_call_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Count"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "required": [
        "segment_id"
      ],
      "title": "UsageSegment",
      "type": "object"
    },
    "UsageSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "cost_basis_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_digests"
                  ]
                },
                {
                  "required": [
                    "cost_observation_count"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-summary",
          "default": "usage-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cost_basis_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Cost Basis Ids",
          "type": "array"
        },
        "cost_observation_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Observation Count"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "pricing_snapshot_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Pricing Snapshot Digests",
          "type": "array"
        },
        "pricing_snapshot_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Pricing Snapshot Ids",
          "type": "array"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "total_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Latency Ms"
        },
        "total_retries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Retries"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        },
        "total_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tool Calls"
        }
      },
      "title": "UsageSummary",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.5.0/stream-run.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accepted_event_count": {
      "minimum": 0,
      "title": "Accepted Event Count",
      "type": "integer"
    },
    "artifact_kind": {
      "const": "stream-run",
      "default": "stream-run",
      "title": "Artifact Kind",
      "type": "string"
    },
    "case_ids": {
      "default": [],
      "items": {
        "maxLength": 512,
        "type": "string"
      },
      "title": "Case Ids",
      "type": "array"
    },
    "duplicate_event_count": {
      "minimum": 0,
      "title": "Duplicate Event Count",
      "type": "integer"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/StreamEventRecord"
      },
      "minItems": 1,
      "title": "Events",
      "type": "array"
    },
    "run_ids": {
      "items": {
        "maxLength": 512,
        "type": "string"
      },
      "minItems": 1,
      "title": "Run Ids",
      "type": "array"
    },
    "schema_version": {
      "default": "0.5.0",
      "enum": [
        "0.2.0",
        "0.3.1",
        "0.4.3",
        "0.5.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "sequence_contract": {
      "$ref": "#/$defs/StreamSequenceContract"
    },
    "source_event_count": {
      "minimum": 0,
      "title": "Source Event Count",
      "type": "integer"
    },
    "stream_id": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Stream Id",
      "type": "string"
    },
    "usage_ledger": {
      "anyOf": [
        {
          "$ref": "#/$defs/UsageLedger"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "usage_summary": {
      "anyOf": [
        {
          "$ref": "#/$defs/UsageSummary"
        },
        {
          "type": "null"
