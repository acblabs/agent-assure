{
  "$defs": {
    "BehaviorChange": {
      "additionalProperties": false,
      "properties": {
        "baseline_value": {
          "title": "Baseline Value",
          "type": "string"
        },
        "candidate_value": {
          "title": "Candidate Value",
          "type": "string"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "field": {
          "title": "Field",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "field",
        "baseline_value",
        "candidate_value"
      ],
      "title": "BehaviorChange",
      "type": "object"
    },
    "CapabilityReport": {
      "additionalProperties": false,
      "properties": {
        "capability_id": {
          "title": "Capability Id",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "capability_id",
        "state",
        "reason"
      ],
      "title": "CapabilityReport",
      "type": "object"
    },
    "ComparisonClassification": {
      "enum": [
        "new_failure",
        "resolved_failure",
        "persistent_failure",
        "unchanged",
        "allowed_behavioral_change",
        "allowed_behavioral_and_provenance_change",
        "provenance_only_change",
        "invalid_comparison",
        "not_evaluated"
      ],
      "title": "ComparisonClassification",
      "type": "string"
    },
    "ComparisonSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.2.0"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "baseline_usage_summary"
                  ]
                },
                {
                  "required": [
                    "candidate_usage_summary"
                  ]
                },
                {
                  "required": [
                    "usage_delta"
                  ]
                }
              ]
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "comparison-summary",
          "default": "comparison-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "baseline_runset_id": {
          "title": "Baseline Runset Id",
          "type": "string"
        },
        "baseline_state": {
          "$ref": "#/$defs/GateState",
          "default": "not_evaluated"
        },
        "baseline_usage_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "candidate_runset_id": {
          "title": "Candidate Runset Id",
          "type": "string"
        },
        "candidate_state": {
          "$ref": "#/$defs/GateState",
          "default": "not_evaluated"
        },
        "candidate_usage_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "classification": {
          "$ref": "#/$defs/ComparisonClassification"
        },
        "environment": {
          "anyOf": [
            {
              "$ref": "#/$defs/EnvironmentInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fixture_equivalence_state": {
          "$ref": "#/$defs/GateState",
          "default": "not_evaluated"
        },
        "provenance_changes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Provenance Changes",
          "type": "array"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "usage_delta": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSummaryDelta"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "verdict_findings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Verdict Findings",
          "type": "array"
        }
      },
      "required": [
        "baseline_runset_id",
        "candidate_runset_id",
        "classification"
      ],
      "title": "ComparisonSummary",
      "type": "object"
    },
    "ControlChange": {
      "additionalProperties": false,
      "properties": {
        "baseline_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/GateState"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "candidate_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/GateState"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "classification": {
          "$ref": "#/$defs/ComparisonClassification"
        },
        "control_id": {
          "title": "Control Id",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "target": {
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "classification",
        "finding_id",
        "case_id",
        "control_id",
        "target",
        "reason_code",
        "message"
      ],
      "title": "ControlChange",
      "type": "object"
    },
    "EnvironmentInfo": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "environment-info",
          "default": "environment-info",
          "title": "Artifact Kind",
          "type": "string"
        },
        "dependency_inventory_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Digest"
        },
        "dependency_inventory_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Inventory Path"
        },
        "git_commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Commit"
        },
        "git_dirty": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Dirty"
        },
        "installed_packages": {
          "default": [],
          "items": {
            "$ref": "#/$defs/InstalledPackage"
          },
          "title": "Installed Packages",
          "type": "array"
        },
        "lockfile_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Digest"
        },
        "lockfile_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lockfile Path"
        },
        "platform": {
          "title": "Platform",
          "type": "string"
        },
        "python_version": {
          "title": "Python Version",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "platform",
        "python_version"
      ],
      "title": "EnvironmentInfo",
      "type": "object"
    },
    "EvaluationMetrics": {
      "additionalProperties": false,
      "properties": {
        "blocking_findings": {
          "minimum": 0,
          "title": "Blocking Findings",
          "type": "integer"
        },
        "evaluated_cases": {
          "minimum": 0,
          "title": "Evaluated Cases",
          "type": "integer"
        },
        "failed_cases": {
          "minimum": 0,
          "title": "Failed Cases",
          "type": "integer"
        },
        "findings_by_control": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Findings By Control",
          "type": "object"
        },
        "findings_by_reason": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Findings By Reason",
          "type": "object"
        },
        "global_blocking_findings": {
          "minimum": 0,
          "title": "Global Blocking Findings",
          "type": "integer"
        },
        "passed_cases": {
          "minimum": 0,
          "title": "Passed Cases",
          "type": "integer"
        },
        "total_cases": {
          "minimum": 0,
          "title": "Total Cases",
          "type": "integer"
        },
        "unevaluated_cases": {
          "minimum": 0,
          "title": "Unevaluated Cases",
          "type": "integer"
        },
        "warning_findings": {
          "minimum": 0,
          "title": "Warning Findings",
          "type": "integer"
        }
      },
      "required": [
        "total_cases",
        "evaluated_cases",
        "unevaluated_cases",
        "passed_cases",
        "failed_cases",
        "warning_findings",
        "blocking_findings",
        "global_blocking_findings",
        "findings_by_reason",
        "findings_by_control"
      ],
      "title": "EvaluationMetrics",
      "type": "object"
    },
    "EvaluationSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.2.0"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "usage_summary"
                  ]
                }
              ]
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "evaluation-summary",
          "default": "evaluation-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "environment": {
          "anyOf": [
            {
              "$ref": "#/$defs/EnvironmentInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Finding"
          },
          "title": "Findings",
          "type": "array"
        },
        "runset_id": {
          "title": "Runset Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        },
        "usage_summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "runset_id",
        "state"
      ],
      "title": "EvaluationSummary",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "finding",
          "default": "finding",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "control_id": {
          "default": "",
          "title": "Control Id",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        },
        "target": {
          "default": "",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "case_id",
        "state",
        "reason_code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "FixtureEquivalenceReport": {
      "additionalProperties": false,
      "properties": {
        "compared_digests": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Compared Digests",
          "type": "array"
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Finding"
          },
          "title": "Findings",
          "type": "array"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "state"
      ],
      "title": "FixtureEquivalenceReport",
      "type": "object"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "InstalledPackage": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "installed-package",
          "default": "installed-package",
          "title": "Artifact Kind",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "InstalledPackage",
      "type": "object"
    },
    "ProvenanceChange": {
      "additionalProperties": false,
      "properties": {
        "baseline_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Baseline Value"
        },
        "candidate_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Value"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "field": {
          "title": "Field",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "field"
      ],
      "title": "ProvenanceChange",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "UsageSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "cost_basis_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_ids"
                  ]
                },
                {
                  "required": [
                    "pricing_snapshot_digests"
                  ]
                },
                {
                  "required": [
                    "cost_observation_count"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-summary",
          "default": "usage-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "cost_basis_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Cost Basis Ids",
          "type": "array"
        },
        "cost_observation_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Observation Count"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "pricing_snapshot_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Pricing Snapshot Digests",
          "type": "array"
        },
        "pricing_snapshot_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Pricing Snapshot Ids",
          "type": "array"
        },
        "schema_version": {
          "default": "0.4.3",
          "enum": [
            "0.3.1",
            "0.4.3"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "total_latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Latency Ms"
        },
        "total_retries": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Retries"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        },
        "total_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tool Calls"
        }
      },
      "title": "UsageSummary",
      "type": "object"
    },
    "UsageSummaryDelta": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "schema_version": {
                "const": "0.3.1"
              }
            },
            "required": [
              "schema_version"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "total_tokens_delta_bps"
                  ]
                },
                {
                  "required": [
                    "total_tool_calls_delta_bps"
                  ]
                },
                {
                  "required": [
                    "total_retries_delta_bps"
                  ]
                },
                {
                  "required": [
                    "total_latency_ms_delta_bps"
                  ]
                },
                {
                  "required": [
                    "estimated_cost_microusd_delta_bps"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "estimated_cost_microusd_delta": {
                "type": "integer"
              }
            },
            "required": [
              "estimated_cost_microusd_delta"
            ]
          },
          "then": {
            "properties": {
              "currency": {
                "const": "USD"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_kind": {
          "const": "usage-summary-delta",
          "default": "usage-summary-delta",
          "title": "Artifact Kind",
          "type": "string"
        },
        "baseline_observed": {
          "title": "Baseline Observed",
          "type": "boolean"
        },
        "candidate_observed": {
          "title": "Candidate Observed",
          "type": "boolean"
        },
        "comparison_state": {
          "enum": [
            "observed",
            "not_observed",
            "baseline_not_observed",
            "candidate_not_observed"
          ],
          "title": "Comparison State",
          "type": "string"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "estimated_cost_microusd_delta": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd Delta"
        },
        "estimated_cost_microusd_delta_bps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Microusd Delta Bps"
        },
        "limitations": {
          "default": [],
          "items": {
