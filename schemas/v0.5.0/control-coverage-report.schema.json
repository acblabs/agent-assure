{
  "$defs": {
    "ControlConditionEvaluation": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "control-condition-evaluation",
          "default": "control-condition-evaluation",
          "title": "Artifact Kind",
          "type": "string"
        },
        "condition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Condition"
        },
        "coverage_state": {
          "$ref": "#/$defs/ControlCoverageState"
        },
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ControlEvidenceRef"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "observed": {
          "title": "Observed",
          "type": "boolean"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "rule_id": {
          "minLength": 1,
          "title": "Rule Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "signal": {
          "minLength": 1,
          "title": "Signal",
          "type": "string"
        }
      },
      "required": [
        "rule_id",
        "signal",
        "observed",
        "coverage_state",
        "rationale"
      ],
      "title": "ControlConditionEvaluation",
      "type": "object"
    },
    "ControlCoverageItem": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "control-coverage-item",
          "default": "control-coverage-item",
          "title": "Artifact Kind",
          "type": "string"
        },
        "atlas_tactic_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Atlas Tactic Ids",
          "type": "array"
        },
        "atlas_technique_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Atlas Technique Ids",
          "type": "array"
        },
        "condition_evaluations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ControlConditionEvaluation"
          },
          "title": "Condition Evaluations",
          "type": "array"
        },
        "control_id": {
          "minLength": 1,
          "title": "Control Id",
          "type": "string"
        },
        "coverage_state": {
          "$ref": "#/$defs/ControlCoverageState"
        },
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ControlEvidenceRef"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "mapping_strength": {
          "anyOf": [
            {
              "$ref": "#/$defs/ControlMappingStrength"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "control_id",
        "title",
        "coverage_state"
      ],
      "title": "ControlCoverageItem",
      "type": "object"
    },
    "ControlCoverageState": {
      "enum": [
        "observed",
        "partially_observed",
        "conditionally_observed",
        "contradictory_evidence_observed",
        "not_observed",
        "not_evaluated",
        "not_applicable",
        "out_of_scope"
      ],
      "title": "ControlCoverageState",
      "type": "string"
    },
    "ControlEvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "control-evidence-ref",
          "default": "control-evidence-ref",
          "title": "Artifact Kind",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "evidence_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Digest"
        },
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "evidence_kind": {
          "minLength": 1,
          "title": "Evidence Kind",
          "type": "string"
        },
        "field_path": {
          "minLength": 1,
          "title": "Field Path",
          "type": "string"
        },
        "schema_version": {
          "default": "0.5.0",
          "enum": [
            "0.2.0",
            "0.3.1",
            "0.4.3",
            "0.5.0"
          ],
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "evidence_kind",
        "evidence_id",
        "field_path",
        "description"
      ],
      "title": "ControlEvidenceRef",
      "type": "object"
    },
    "ControlFramework": {
      "enum": [
        "nist-ai-rmf",
        "owasp-llm-top-10-2025",
        "iso-iec-42001",
        "mitre-atlas-2026-06"
      ],
      "title": "ControlFramework",
      "type": "string"
    },
    "ControlMappingStrength": {
      "enum": [
        "direct",
        "partial",
        "adjacent",
        "gap",
        "not_applicable"
      ],
      "title": "ControlMappingStrength",
      "type": "string"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.5.0/control-coverage-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "control-coverage-report",
      "default": "control-coverage-report",
      "title": "Artifact Kind",
      "type": "string"
    },
    "coverage_state_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Coverage State Counts",
      "type": "object"
    },
    "evidence_packet_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Evidence Packet Digest",
      "type": "string"
    },
    "evidence_packet_id": {
      "minLength": 1,
      "title": "Evidence Packet Id",
      "type": "string"
    },
    "framework": {
      "$ref": "#/$defs/ControlFramework"
    },
    "framework_version": {
      "minLength": 1,
      "title": "Framework Version",
      "type": "string"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/ControlCoverageItem"
      },
      "title": "Items",
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "mapping_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Mapping Digest",
      "type": "string"
    },
    "mapping_version": {
      "minLength": 1,
      "title": "Mapping Version",
      "type": "string"
    },
    "report_id": {
      "minLength": 1,
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.5.0",
      "enum": [
        "0.2.0",
        "0.3.1",
        "0.4.3",
        "0.5.0"
      ],
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "report_id",
    "framework",
    "framework_version",
    "mapping_version",
    "mapping_digest",
    "evidence_packet_id",
    "evidence_packet_digest",
    "coverage_state_counts",
    "items",
    "limitations"
  ],
  "title": "ControlCoverageReport",
  "type": "object"
}
