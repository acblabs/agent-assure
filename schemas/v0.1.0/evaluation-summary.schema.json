{
  "$defs": {
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "finding",
          "default": "finding",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "finding_id",
        "case_id",
        "state",
        "reason_code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.1.0/evaluation-summary.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "evaluation-summary",
      "default": "evaluation-summary",
      "title": "Artifact Kind",
      "type": "string"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "runset_id": {
      "title": "Runset Id",
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/GateState"
    }
  },
  "required": [
    "runset_id",
    "state"
  ],
  "title": "EvaluationSummary",
  "type": "object"
}
