{
  "$defs": {
    "ComparisonClassification": {
      "enum": [
        "equivalent",
        "provenance_only",
        "behavioral_regression",
        "invalid_comparison"
      ],
      "title": "ComparisonClassification",
      "type": "string"
    },
    "ComparisonSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "comparison-summary",
          "default": "comparison-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "baseline_runset_id": {
          "title": "Baseline Runset Id",
          "type": "string"
        },
        "candidate_runset_id": {
          "title": "Candidate Runset Id",
          "type": "string"
        },
        "classification": {
          "$ref": "#/$defs/ComparisonClassification"
        },
        "provenance_changes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Provenance Changes",
          "type": "array"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "verdict_findings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Verdict Findings",
          "type": "array"
        }
      },
      "required": [
        "baseline_runset_id",
        "candidate_runset_id",
        "classification"
      ],
      "title": "ComparisonSummary",
      "type": "object"
    },
    "EvaluationSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "evaluation-summary",
          "default": "evaluation-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Finding"
          },
          "title": "Findings",
          "type": "array"
        },
        "runset_id": {
          "title": "Runset Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "runset_id",
        "state"
      ],
      "title": "EvaluationSummary",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "finding",
          "default": "finding",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "reason_code": {
          "$ref": "#/$defs/ReasonCode"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "finding_id",
        "case_id",
        "state",
        "reason_code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.1.0/evidence-packet.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "evidence-packet",
      "default": "evidence-packet",
      "title": "Artifact Kind",
      "type": "string"
    },
    "comparison": {
      "anyOf": [
        {
          "$ref": "#/$defs/ComparisonSummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "evaluation": {
      "$ref": "#/$defs/EvaluationSummary"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "packet_id": {
      "title": "Packet Id",
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "packet_id",
    "evaluation",
    "limitations"
  ],
  "title": "EvidencePacket",
  "type": "object"
}
