{
  "$defs": {
    "AgentRunRecord": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "agent-run-record",
          "default": "agent-run-record",
          "title": "Artifact Kind",
          "type": "string"
        },
        "case_id": {
          "minLength": 1,
          "title": "Case Id",
          "type": "string"
        },
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "execution_mode": {
          "$ref": "#/$defs/ExecutionMode",
          "default": "fixture"
        },
        "human_review_performed": {
          "default": false,
          "title": "Human Review Performed",
          "type": "boolean"
        },
        "human_review_required": {
          "default": false,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "input_summary": {
          "title": "Input Summary",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "outcome": {
          "title": "Outcome",
          "type": "string"
        },
        "output_summary": {
          "title": "Output Summary",
          "type": "string"
        },
        "pipeline_id": {
          "minLength": 1,
          "title": "Pipeline Id",
          "type": "string"
        },
        "policy_results": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PolicyResult"
          },
          "title": "Policy Results",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance",
          "default": {
            "artifact_kind": "provenance",
            "code_digest": null,
            "configuration_digest": null,
            "fixture_manifest_digest": null,
            "model_identifier": null,
            "policy_bundle_digest": null,
            "prompt_digest": null,
            "retrieval_corpus_digest": null,
            "schema_version": "0.1.0",
            "tool_schema_digest": null
          }
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "recommendation": {
          "title": "Recommendation",
          "type": "string"
        },
        "run_id": {
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "tools": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "required": [
        "run_id",
        "case_id",
        "pipeline_id",
        "recommendation",
        "outcome",
        "input_summary",
        "output_summary"
      ],
      "title": "AgentRunRecord",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "evidence-ref",
          "default": "evidence-ref",
          "title": "Artifact Kind",
          "type": "string"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Claim Ids",
          "type": "array"
        },
        "ref_id": {
          "title": "Ref Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "source_id"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "ExecutionMode": {
      "enum": [
        "fixture",
        "live"
      ],
      "title": "ExecutionMode",
      "type": "string"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "PolicyResult": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "policy-result",
          "default": "policy-result",
          "title": "Artifact Kind",
          "type": "string"
        },
        "gate_profile": {
          "default": "default",
          "title": "Gate Profile",
          "type": "string"
        },
        "message": {
          "default": "",
          "title": "Message",
          "type": "string"
        },
        "policy_id": {
          "title": "Policy Id",
          "type": "string"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "info"
        },
        "state": {
          "$ref": "#/$defs/GateState"
        }
      },
      "required": [
        "policy_id",
        "state"
      ],
      "title": "PolicyResult",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "provenance",
          "default": "provenance",
          "title": "Artifact Kind",
          "type": "string"
        },
        "code_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Digest"
        },
        "configuration_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Configuration Digest"
        },
        "fixture_manifest_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fixture Manifest Digest"
        },
        "model_identifier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Identifier"
        },
        "policy_bundle_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Policy Bundle Digest"
        },
        "prompt_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Digest"
        },
        "retrieval_corpus_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieval Corpus Digest"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "tool_schema_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Schema Digest"
        }
      },
      "title": "Provenance",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "blocker"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.1.0/run-set.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "run-set",
      "default": "run-set",
      "title": "Artifact Kind",
      "type": "string"
    },
    "runs": {
      "items": {
        "$ref": "#/$defs/AgentRunRecord"
      },
      "title": "Runs",
      "type": "array"
    },
    "runset_id": {
      "title": "Runset Id",
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "suite_id": {
      "title": "Suite Id",
      "type": "string"
    }
  },
  "required": [
    "runset_id",
    "suite_id",
    "runs"
  ],
  "title": "RunSet",
  "type": "object"
}
