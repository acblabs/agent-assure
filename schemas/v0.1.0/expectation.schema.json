{
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.1.0/expectation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_outcomes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Allowed Outcomes",
      "type": "array"
    },
    "artifact_kind": {
      "const": "expectation",
      "default": "expectation",
      "title": "Artifact Kind",
      "type": "string"
    },
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "expectation_id": {
      "minLength": 1,
      "title": "Expectation Id",
      "type": "string"
    },
    "expected_recommendation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Recommendation"
    },
    "forbidden_outcomes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Forbidden Outcomes",
      "type": "array"
    },
    "material_claim_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Material Claim Ids",
      "type": "array"
    },
    "required_evidence_refs": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Required Evidence Refs",
      "type": "array"
    },
    "required_human_review": {
      "default": false,
      "title": "Required Human Review",
      "type": "boolean"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "expectation_id",
    "case_id"
  ],
  "title": "Expectation",
  "type": "object"
}
