{
  "$defs": {
    "FixtureManifestEntry": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "fixture-manifest-entry",
          "default": "fixture-manifest-entry",
          "title": "Artifact Kind",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "schema_version": {
          "const": "0.1.0",
          "default": "0.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "sha256",
        "size_bytes"
      ],
      "title": "FixtureManifestEntry",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.1.0/fixture-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "fixture-manifest",
      "default": "fixture-manifest",
      "title": "Artifact Kind",
      "type": "string"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/FixtureManifestEntry"
      },
      "title": "Entries",
      "type": "array"
    },
    "fixture_roots": {
      "items": {
        "type": "string"
      },
      "title": "Fixture Roots",
      "type": "array"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "suite_id": {
      "minLength": 1,
      "title": "Suite Id",
      "type": "string"
    },
    "suite_version": {
      "minLength": 1,
      "title": "Suite Version",
      "type": "string"
    }
  },
  "required": [
    "suite_id",
    "suite_version",
    "fixture_roots",
    "entries"
  ],
  "title": "FixtureManifest",
  "type": "object"
}
