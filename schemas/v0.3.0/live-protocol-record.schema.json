{
  "$defs": {
    "AdvancedAnalysisPlan": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "advanced-analysis-plan",
          "default": "advanced-analysis-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/StatisticalEndpointPlan"
          },
          "minItems": 1,
          "title": "Endpoints",
          "type": "array"
        },
        "familywise_alpha": {
          "default": "0.050000",
          "pattern": "^0\\.[0-9]{6}$",
          "title": "Familywise Alpha",
          "type": "string"
        },
        "multiplicity_method": {
          "default": "none",
          "enum": [
            "none",
            "single_endpoint",
            "bonferroni"
          ],
          "title": "Multiplicity Method",
          "type": "string"
        },
        "observed_icc_confirmatory_use": {
          "default": "disabled",
          "enum": [
            "disabled",
            "large_cluster_threshold",
            "external_review"
          ],
          "title": "Observed Icc Confirmatory Use",
          "type": "string"
        },
        "observed_icc_large_cluster_threshold": {
          "anyOf": [
            {
              "minimum": 30,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Icc Large Cluster Threshold"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "endpoints"
      ],
      "title": "AdvancedAnalysisPlan",
      "type": "object"
    },
    "DriftMetricPlan": {
      "additionalProperties": false,
      "properties": {
        "analysis_methods": {
          "default": [
            "descriptive_trend"
          ],
          "items": {
            "enum": [
              "descriptive_trend",
              "lag1_autocorrelation",
              "ar1_summary",
              "state_space_ewma"
            ],
            "type": "string"
          },
          "title": "Analysis Methods",
          "type": "array"
        },
        "ar1_review_threshold": {
          "default": "0.500000",
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "title": "Ar1 Review Threshold",
          "type": "string"
        },
        "artifact_kind": {
          "const": "drift-metric-plan",
          "default": "drift-metric-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "autocorrelation_review_threshold": {
          "default": "0.500000",
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "title": "Autocorrelation Review Threshold",
          "type": "string"
        },
        "interpretation": {
          "default": "exploratory",
          "enum": [
            "confirmatory",
            "exploratory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metric": {
          "enum": [
            "expectation_pass_rate",
            "reason_code_rate",
            "exclusion_rate",
            "retry_rate",
            "rate_limit_rate",
            "latency_p50_ms",
            "cost_total_usd"
          ],
          "title": "Metric",
          "type": "string"
        },
        "minimum_dependence_windows": {
          "default": 8,
          "minimum": 8,
          "title": "Minimum Dependence Windows",
          "type": "integer"
        },
        "minimum_observations_per_window": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Observations Per Window",
          "type": "integer"
        },
        "minimum_state_space_windows": {
          "default": 6,
          "minimum": 6,
          "title": "Minimum State Space Windows",
          "type": "integer"
        },
        "minimum_windows": {
          "default": 6,
          "minimum": 2,
          "title": "Minimum Windows",
          "type": "integer"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "slope_review_threshold": {
          "default": "0.050000",
          "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
          "title": "Slope Review Threshold",
          "type": "string"
        },
        "state_space_alpha": {
          "default": "0.300000",
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "title": "State Space Alpha",
          "type": "string"
        },
        "step_review_threshold": {
          "default": "0.100000",
          "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
          "title": "Step Review Threshold",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "label"
      ],
      "title": "DriftMetricPlan",
      "type": "object"
    },
    "DriftMonitoringPlan": {
      "additionalProperties": false,
      "properties": {
        "allow_bounded_sensitivity_on_comparability_failure": {
          "default": false,
          "title": "Allow Bounded Sensitivity On Comparability Failure",
          "type": "boolean"
        },
        "artifact_kind": {
          "const": "drift-monitoring-plan",
          "default": "drift-monitoring-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "comparability_mode": {
          "default": "strict_protocol_digest",
          "enum": [
            "strict_protocol_digest",
            "material_fields"
          ],
          "title": "Comparability Mode",
          "type": "string"
        },
        "drift_hypothesis": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Drift Hypothesis"
        },
        "interpretation": {
          "default": "exploratory",
          "enum": [
            "confirmatory",
            "exploratory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "known_provider_version_unknowns": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Known Provider Version Unknowns",
          "type": "array"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/DriftMetricPlan"
          },
          "minItems": 1,
          "title": "Metrics",
          "type": "array"
        },
        "ordering_variable": {
          "default": "window_index",
          "enum": [
            "window_index",
            "window_start_utc",
            "release_sequence",
            "provider_version_window"
          ],
          "title": "Ordering Variable",
          "type": "string"
        },
        "plan_id": {
          "minLength": 1,
          "title": "Plan Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "plan_id",
        "metrics"
      ],
      "title": "DriftMonitoringPlan",
      "type": "object"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    },
    "StatisticalEndpointPlan": {
      "additionalProperties": false,
      "properties": {
        "analysis_method": {
          "default": "descriptive_rate",
          "enum": [
            "cluster_t_interval",
            "cluster_bootstrap_percentile",
            "poisson_upper_bound",
            "hierarchical_binomial_summary",
            "beta_binomial_cluster_summary",
            "descriptive_rate"
          ],
          "title": "Analysis Method",
          "type": "string"
        },
        "artifact_kind": {
          "const": "statistical-endpoint-plan",
          "default": "statistical-endpoint-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "endpoint_id": {
          "minLength": 1,
          "title": "Endpoint Id",
          "type": "string"
        },
        "endpoint_kind": {
          "enum": [
            "expectation_pass_rate",
            "reason_code_rate",
            "critical_event_rate",
            "exclusion_rate",
            "outcome_rate"
          ],
          "title": "Endpoint Kind",
          "type": "string"
        },
        "exchangeability_assumption": {
          "default": "not_applicable",
          "enum": [
            "not_applicable",
            "baseline_candidate_relabeling"
          ],
          "title": "Exchangeability Assumption",
          "type": "string"
        },
        "exposure_unit": {
          "default": "observation",
          "minLength": 1,
          "title": "Exposure Unit",
          "type": "string"
        },
        "family_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Family Id"
        },
        "hierarchy_rank": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hierarchy Rank"
        },
        "interpretation": {
          "default": "exploratory",
          "enum": [
            "confirmatory",
            "exploratory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "minimum_clusters": {
          "default": 30,
          "minimum": 1,
          "title": "Minimum Clusters",
          "type": "integer"
        },
        "minimum_events": {
          "default": 0,
          "minimum": 0,
          "title": "Minimum Events",
          "type": "integer"
        },
        "minimum_observations": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Observations",
          "type": "integer"
        },
        "outcome": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outcome"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "role": {
          "default": "secondary",
          "enum": [
            "primary",
            "secondary",
            "diagnostic"
          ],
          "title": "Role",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "endpoint_id",
        "label",
        "endpoint_kind"
      ],
      "title": "StatisticalEndpointPlan",
      "type": "object"
    },
    "TrajectoryAnalysisPlan": {
      "additionalProperties": false,
      "properties": {
        "analysis_methods": {
          "default": [
            "observable_transition_profile",
            "sequence_invariant_check",
            "event_process_summary",
            "burst_window_count"
          ],
          "items": {
            "enum": [
              "observable_transition_profile",
              "sequence_invariant_check",
              "event_process_summary",
              "burst_window_count"
            ],
            "type": "string"
          },
          "title": "Analysis Methods",
          "type": "array"
        },
        "artifact_kind": {
          "const": "trajectory-analysis-plan",
          "default": "trajectory-analysis-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "burst_count_threshold": {
          "default": 3,
          "minimum": 2,
          "title": "Burst Count Threshold",
          "type": "integer"
        },
        "burst_window_seconds": {
          "default": 60,
          "minimum": 1,
          "title": "Burst Window Seconds",
          "type": "integer"
        },
        "interpretation": {
          "default": "exploratory",
          "enum": [
            "exploratory",
            "confirmatory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "invariants": {
          "default": [],
          "items": {
            "$ref": "#/$defs/TrajectoryInvariantPlan"
          },
          "title": "Invariants",
          "type": "array"
        },
        "minimum_event_count": {
          "default": 3,
          "minimum": 0,
          "title": "Minimum Event Count",
          "type": "integer"
        },
        "minimum_event_exposure": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Event Exposure",
          "type": "integer"
        },
        "minimum_observations": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Observations",
          "type": "integer"
        },
        "minimum_transition_support": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Transition Support",
          "type": "integer"
        },
        "plan_id": {
          "minLength": 1,
          "title": "Plan Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "plan_id"
      ],
      "title": "TrajectoryAnalysisPlan",
      "type": "object"
    },
    "TrajectoryInvariantPlan": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "trajectory-invariant-plan",
          "default": "trajectory-invariant-plan",
          "title": "Artifact Kind",
          "type": "string"
        },
        "before_state": {
          "anyOf": [
            {
              "enum": [
                "start",
                "request_assembly",
                "provider_call",
                "tool_call",
                "evidence_check",
                "policy_check",
                "redaction_check",
                "human_review",
                "verdict",
                "excluded",
                "emergency"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Before State"
        },
        "category": {
          "default": "governance_control_failure",
          "enum": [
            "governance_control_failure",
            "operational_reliability_warning"
          ],
          "title": "Category",
          "type": "string"
        },
        "forbidden_states": {
          "default": [],
          "items": {
            "enum": [
              "start",
              "request_assembly",
              "provider_call",
              "tool_call",
              "evidence_check",
              "policy_check",
              "redaction_check",
              "human_review",
              "verdict",
              "excluded",
              "emergency"
            ],
            "type": "string"
          },
          "title": "Forbidden States",
          "type": "array"
        },
        "interpretation": {
          "default": "exploratory",
          "enum": [
            "exploratory",
            "confirmatory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "invariant_id": {
          "minLength": 1,
          "title": "Invariant Id",
          "type": "string"
        },
        "invariant_type": {
          "enum": [
            "forbidden_state",
            "required_review_for_approval",
            "claim_evidence_before_approval",
            "attempt_retry_consistency"
          ],
          "title": "Invariant Type",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "minimum_observations": {
          "default": 1,
          "minimum": 1,
          "title": "Minimum Observations",
          "type": "integer"
        },
        "required_state": {
          "anyOf": [
            {
              "enum": [
                "start",
                "request_assembly",
                "provider_call",
                "tool_call",
                "evidence_check",
                "policy_check",
                "redaction_check",
                "human_review",
                "verdict",
                "excluded",
                "emergency"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Required State"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "invariant_id",
        "label",
        "invariant_type"
      ],
      "title": "TrajectoryInvariantPlan",
      "type": "object"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.2.0/live-protocol-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "advanced_analysis_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/AdvancedAnalysisPlan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "allowed_exclusion_reasons": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Allowed Exclusion Reasons",
      "type": "array"
    },
    "analysis_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Analysis Digest",
      "type": "string"
    },
    "analysis_method": {
      "default": "paired_cluster_t_interval",
      "enum": [
        "paired_cluster_t_interval",
        "paired_cluster_bootstrap_percentile",
        "paired_cluster_permutation_exact",
        "paired_cluster_permutation_monte_carlo",
        "fixed_reference_cluster_t_interval",
        "cluster_t_interval",
        "exploratory"
      ],
      "title": "Analysis Method",
      "type": "string"
    },
    "approved_data_boundary": {
      "minLength": 1,
      "title": "Approved Data Boundary",
      "type": "string"
    },
    "artifact_kind": {
      "const": "live-protocol-record",
      "default": "live-protocol-record",
      "title": "Artifact Kind",
      "type": "string"
    },
    "assumed_intraclass_correlation": {
      "pattern": "^0\\.[0-9]{6}$",
      "title": "Assumed Intraclass Correlation",
      "type": "string"
    },
    "baseline_group_id": {
      "default": "overall",
      "title": "Baseline Group Id",
      "type": "string"
    },
    "baseline_mode": {
      "default": "concurrent_paired",
      "enum": [
        "concurrent_paired",
        "fixed_reference"
      ],
      "title": "Baseline Mode",
      "type": "string"
    },
    "candidate_group_id": {
      "default": "overall",
      "title": "Candidate Group Id",
      "type": "string"
    },
    "cluster_by": {
      "default": "case_id",
      "enum": [
        "case_id",
        "source_group_id"
      ],
      "title": "Cluster By",
      "type": "string"
    },
    "confidence_level": {
      "const": "0.950000",
      "default": "0.950000",
      "title": "Confidence Level",
      "type": "string"
    },
    "design_effect": {
      "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
      "title": "Design Effect",
      "type": "string"
    },
    "drift_monitoring_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/DriftMonitoringPlan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "exclusion_policy": {
      "minLength": 1,
      "title": "Exclusion Policy",
      "type": "string"
    },
    "fixed_reference_pass_rate": {
      "anyOf": [
        {
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fixed Reference Pass Rate"
    },
    "hypothesis_family": {
      "default": "governance_control_non_inferiority",
      "enum": [
        "governance_control_non_inferiority",
        "provider_model_comparison",
        "regression_detection"
      ],
      "title": "Hypothesis Family",
      "type": "string"
    },
    "max_cost_per_observation_usd": {
      "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
      "title": "Max Cost Per Observation Usd",
      "type": "string"
    },
    "max_exclusion_rate": {
      "default": "0.000000",
      "pattern": "^0\\.[0-9]{6}$",
      "title": "Max Exclusion Rate",
      "type": "string"
    },
    "max_generated_tokens": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Generated Tokens"
    },
    "max_rate_limit_events": {
      "default": 0,
      "minimum": 0,
      "title": "Max Rate Limit Events",
      "type": "integer"
    },
    "max_requests": {
      "minimum": 1,
      "title": "Max Requests",
      "type": "integer"
    },
    "max_retries": {
      "default": 2,
      "minimum": 0,
      "title": "Max Retries",
      "type": "integer"
    },
    "max_total_cost_usd": {
      "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
      "title": "Max Total Cost Usd",
      "type": "string"
    },
    "max_total_tokens": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Total Tokens"
    },
    "non_inferiority_margin": {
      "pattern": "^0\\.[0-9]{6}$",
      "title": "Non Inferiority Margin",
      "type": "string"
    },
    "planned_clusters": {
      "minimum": 1,
      "title": "Planned Clusters",
      "type": "integer"
    },
    "planned_effective_n": {
      "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
      "title": "Planned Effective N",
      "type": "string"
    },
    "planned_observations": {
      "minimum": 1,
      "title": "Planned Observations",
      "type": "integer"
    },
    "planned_observations_per_cluster": {
      "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
      "title": "Planned Observations Per Cluster",
      "type": "string"
    },
    "planned_repetitions": {
      "minimum": 1,
      "title": "Planned Repetitions",
      "type": "integer"
    },
    "policy_bundle_digest": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Policy Bundle Digest",
      "type": "string"
    },
    "primary_endpoint": {
      "default": "expectation_pass_rate",
      "enum": [
