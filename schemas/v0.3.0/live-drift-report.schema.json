{
  "$defs": {
    "DriftComparabilityResult": {
      "additionalProperties": false,
      "properties": {
        "analysis_method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Analysis Method"
        },
        "analysis_method_matches": {
          "title": "Analysis Method Matches",
          "type": "boolean"
        },
        "artifact_kind": {
          "const": "drift-comparability-result",
          "default": "drift-comparability-result",
          "title": "Artifact Kind",
          "type": "string"
        },
        "baseline_mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Baseline Mode"
        },
        "baseline_mode_matches": {
          "title": "Baseline Mode Matches",
          "type": "boolean"
        },
        "compared_windows": {
          "minimum": 0,
          "title": "Compared Windows",
          "type": "integer"
        },
        "failures": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Failures",
          "type": "array"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "material_fields_match": {
          "title": "Material Fields Match",
          "type": "boolean"
        },
        "policy_bundle_digest_matches": {
          "title": "Policy Bundle Digest Matches",
          "type": "boolean"
        },
        "protocol_digest_matches": {
          "title": "Protocol Digest Matches",
          "type": "boolean"
        },
        "reference_protocol_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Protocol Digest"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "exploratory",
            "invalid"
          ],
          "title": "Status",
          "type": "string"
        },
        "suite_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suite Id"
        },
        "suite_matches": {
          "title": "Suite Matches",
          "type": "boolean"
        },
        "suite_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suite Version"
        },
        "tool_schema_digest_matches": {
          "title": "Tool Schema Digest Matches",
          "type": "boolean"
        }
      },
      "required": [
        "status",
        "compared_windows",
        "suite_matches",
        "baseline_mode_matches",
        "analysis_method_matches",
        "protocol_digest_matches",
        "material_fields_match",
        "tool_schema_digest_matches",
        "policy_bundle_digest_matches"
      ],
      "title": "DriftComparabilityResult",
      "type": "object"
    },
    "DriftMetricDiagnostic": {
      "additionalProperties": false,
      "properties": {
        "analysis_methods": {
          "items": {
            "enum": [
              "descriptive_trend",
              "lag1_autocorrelation",
              "ar1_summary",
              "state_space_ewma"
            ],
            "type": "string"
          },
          "title": "Analysis Methods",
          "type": "array"
        },
        "ar1_innovation_variance": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ar1 Innovation Variance"
        },
        "ar1_intercept": {
          "anyOf": [
            {
              "pattern": "^-?(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ar1 Intercept"
        },
        "ar1_phi": {
          "anyOf": [
            {
              "pattern": "^-?(0|1)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ar1 Phi"
        },
        "artifact_kind": {
          "const": "drift-metric-diagnostic",
          "default": "drift-metric-diagnostic",
          "title": "Artifact Kind",
          "type": "string"
        },
        "dependence_signal": {
          "default": "none",
          "enum": [
            "none",
            "review",
            "invalid"
          ],
          "title": "Dependence Signal",
          "type": "string"
        },
        "first_value": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "First Value"
        },
        "interpretation": {
          "enum": [
            "confirmatory",
            "exploratory"
          ],
          "title": "Interpretation",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "lag1_autocorrelation": {
          "anyOf": [
            {
              "pattern": "^-?(0|1)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lag1 Autocorrelation"
        },
        "last_value": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Value"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "max_step_change": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Step Change"
        },
        "mean_value": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Value"
        },
        "metric": {
          "enum": [
            "expectation_pass_rate",
            "reason_code_rate",
            "exclusion_rate",
            "retry_rate",
            "rate_limit_rate",
            "latency_p50_ms",
            "cost_total_usd"
          ],
          "title": "Metric",
          "type": "string"
        },
        "missing_windows": {
          "minimum": 0,
          "title": "Missing Windows",
          "type": "integer"
        },
        "observations": {
          "minimum": 0,
          "title": "Observations",
          "type": "integer"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "review_reasons": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Review Reasons",
          "type": "array"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "slope_per_window": {
          "anyOf": [
            {
              "pattern": "^-?(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slope Per Window"
        },
        "state_estimate": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftStateEstimate"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "stationarity_signal": {
          "default": "none",
          "enum": [
            "none",
            "review",
            "invalid"
          ],
          "title": "Stationarity Signal",
          "type": "string"
        },
        "windows": {
          "minimum": 0,
          "title": "Windows",
          "type": "integer"
        }
      },
      "required": [
        "metric",
        "label",
        "interpretation",
        "analysis_methods",
        "prerequisite_status",
        "windows",
        "observations",
        "missing_windows"
      ],
      "title": "DriftMetricDiagnostic",
      "type": "object"
    },
    "DriftStateEstimate": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "drift-state-estimate",
          "default": "drift-state-estimate",
          "title": "Artifact Kind",
          "type": "string"
        },
        "innovation_variance": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Innovation Variance"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "latest_drift_per_window": {
          "anyOf": [
            {
              "pattern": "^-?(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latest Drift Per Window"
        },
        "latest_level": {
          "anyOf": [
            {
              "pattern": "^-?(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latest Level"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "metric": {
          "enum": [
            "expectation_pass_rate",
            "reason_code_rate",
            "exclusion_rate",
            "retry_rate",
            "rate_limit_rate",
            "latency_p50_ms",
            "cost_total_usd"
          ],
          "title": "Metric",
          "type": "string"
        },
        "prerequisite_status": {
          "enum": [
            "met",
            "exploratory",
            "invalid"
          ],
          "title": "Prerequisite Status",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "smoothing_alpha": {
          "pattern": "^(0|1)\\.[0-9]{6}$",
          "title": "Smoothing Alpha",
          "type": "string"
        },
        "state_name": {
          "enum": [
            "governance_health",
            "control_reliability",
            "drift_state"
          ],
          "title": "State Name",
          "type": "string"
        }
      },
      "required": [
        "state_name",
        "metric",
        "label",
        "prerequisite_status",
        "smoothing_alpha"
      ],
      "title": "DriftStateEstimate",
      "type": "object"
    },
    "DriftWindowMetric": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "drift-window-metric",
          "default": "drift-window-metric",
          "title": "Artifact Kind",
          "type": "string"
        },
        "denominator": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Denominator"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metric": {
          "enum": [
            "expectation_pass_rate",
            "reason_code_rate",
            "exclusion_rate",
            "retry_rate",
            "rate_limit_rate",
            "latency_p50_ms",
            "cost_total_usd"
          ],
          "title": "Metric",
          "type": "string"
        },
        "numerator": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Numerator"
        },
        "reason_codes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ReasonCode"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "source": {
          "enum": [
            "pooled_rate",
            "observation_rate",
            "distribution_p50",
            "distribution_total",
            "reason_code_rate"
          ],
          "title": "Source",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "metric",
        "label",
        "source"
      ],
      "title": "DriftWindowMetric",
      "type": "object"
    },
    "DriftWindowSummary": {
      "additionalProperties": false,
      "properties": {
        "analysis_method": {
          "minLength": 1,
          "title": "Analysis Method",
          "type": "string"
        },
        "artifact_kind": {
          "const": "drift-window-summary",
          "default": "drift-window-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "baseline_mode": {
          "anyOf": [
            {
              "enum": [
                "concurrent_paired",
                "fixed_reference"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Baseline Mode"
        },
        "excluded_observations": {
          "minimum": 0,
          "title": "Excluded Observations",
          "type": "integer"
        },
        "included_observations": {
          "minimum": 0,
          "title": "Included Observations",
          "type": "integer"
        },
        "metrics": {
          "default": [],
          "items": {
            "$ref": "#/$defs/DriftWindowMetric"
          },
          "title": "Metrics",
          "type": "array"
        },
        "observation_window_end_utc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Window End Utc"
        },
        "observation_window_start_utc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observation Window Start Utc"
        },
        "observations": {
          "minimum": 0,
          "title": "Observations",
          "type": "integer"
        },
        "policy_bundle_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Policy Bundle Digests",
          "type": "array"
        },
        "protocol_digest": {
          "anyOf": [
            {
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Protocol Digest"
        },
        "protocol_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Protocol Id"
        },
        "provider_version_keys": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Provider Version Keys",
          "type": "array"
        },
        "provider_version_unknown": {
          "default": false,
          "title": "Provider Version Unknown",
          "type": "boolean"
        },
        "runset_id": {
          "minLength": 1,
          "title": "Runset Id",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "suite_id": {
          "minLength": 1,
          "title": "Suite Id",
          "type": "string"
        },
        "suite_version": {
          "minLength": 1,
          "title": "Suite Version",
          "type": "string"
        },
        "tool_schema_digests": {
          "default": [],
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "title": "Tool Schema Digests",
          "type": "array"
        },
        "window_id": {
          "minLength": 1,
          "title": "Window Id",
          "type": "string"
        },
        "window_index": {
          "minimum": 0,
          "title": "Window Index",
          "type": "integer"
        }
      },
      "required": [
        "window_id",
        "window_index",
        "runset_id",
        "suite_id",
        "suite_version",
        "analysis_method",
        "observations",
        "included_observations",
        "excluded_observations"
      ],
      "title": "DriftWindowSummary",
      "type": "object"
    },
    "GateState": {
      "enum": [
        "pass",
        "fail",
        "warn",
        "not_evaluated"
      ],
      "title": "GateState",
      "type": "string"
    },
    "ReasonCode": {
      "enum": [
        "EXPECTED_OUTCOME_MISMATCH",
        "FORBIDDEN_OUTCOME",
        "MATERIAL_CLAIM_MISSING_EVIDENCE",
        "REQUIRED_SOURCE_MISSING",
        "POLICY_FAILED",
        "REQUIRED_HUMAN_REVIEW_ABSENT",
        "REVIEW_BOUNDARY_FAILED",
        "FORBIDDEN_PROVIDER",
        "FORBIDDEN_TOOL",
        "STRUCTURED_OUTPUT_INVALID",
        "REDACTION_FAILED",
        "RAW_SENSITIVE_CONTENT",
        "PROMPT_INJECTION_BOUNDARY",
        "RUNTIME_FAILED",
        "VALID_RECORD_MISSING",
        "FIXTURE_EQUIVALENCE_FAILED",
        "NON_NFC_STRING",
        "NON_FINITE_NUMBER",
        "NOT_EVALUATED"
      ],
      "title": "ReasonCode",
      "type": "string"
    }
  },
  "$id": "https://acblabs.github.io/agent-assure/schemas/v0.2.0/live-drift-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_kind": {
      "const": "live-drift-report",
      "default": "live-drift-report",
      "title": "Artifact Kind",
      "type": "string"
    },
    "comparability": {
      "$ref": "#/$defs/DriftComparabilityResult"
    },
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/DriftMetricDiagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    },
    "drift_plan_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Drift Plan Id"
    },
    "interpretation": {
      "default": "exploratory",
      "enum": [
        "confirmatory",
        "exploratory"
      ],
      "title": "Interpretation",
      "type": "string"
    },
    "limitations": {
      "default": [
        "cross-window monitoring is a review signal and is not a release-verdict gate",
        "stationarity or drift signals do not establish safety, compliance, clinical validity, provider quality, or model intent",
        "latent-state summaries describe governance health, control reliability, or drift state from observable records only"
      ],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "monitoring_status": {
      "enum": [
        "valid",
        "exploratory",
        "invalid"
      ],
      "title": "Monitoring Status",
      "type": "string"
    },
    "observation_window_end_utc": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observation Window End Utc"
    },
    "observation_window_start_utc": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observation Window Start Utc"
    },
    "ordering_variable": {
      "default": "window_index",
      "enum": [
        "window_index",
        "window_start_utc",
        "release_sequence",
        "provider_version_window"
      ],
      "title": "Ordering Variable",
      "type": "string"
    },
    "protocol_digest": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Protocol Digest"
    },
    "protocol_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Protocol Id"
    },
    "report_id": {
      "minLength": 1,
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "const": "0.2.0",
      "default": "0.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/GateState",
      "default": "not_evaluated"
    },
    "suite_id": {
      "minLength": 1,
      "title": "Suite Id",
      "type": "string"
    },
    "suite_version": {
      "minLength": 1,
      "title": "Suite Version",
      "type": "string"
    },
    "windows": {
      "items": {
        "$ref": "#/$defs/DriftWindowSummary"
      },
      "title": "Windows",
      "type": "array"
    }
  },
  "required": [
    "report_id",
    "suite_id",
    "suite_version",
    "monitoring_status",
    "comparability",
    "windows",
