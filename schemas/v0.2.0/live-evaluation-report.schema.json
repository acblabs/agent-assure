              "type": "null"
            }
          ],
          "default": null,
          "title": "Max"
        },
        "mean": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean"
        },
        "metric": {
          "enum": [
            "latency_ms",
            "estimated_cost_usd"
          ],
          "title": "Metric",
          "type": "string"
        },
        "min": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min"
        },
        "p50": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "P50"
        },
        "p95": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "P95"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "total": {
          "anyOf": [
            {
              "pattern": "^(0|[1-9][0-9]*)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total"
        }
      },
      "required": [
        "metric",
        "count"
      ],
      "title": "LiveDistribution",
      "type": "object"
    },
