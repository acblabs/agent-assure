{
  "$defs": {
    "ClusterCorrelationSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "cluster-correlation-summary",
          "default": "cluster-correlation-summary",
          "title": "Artifact Kind",
          "type": "string"
        },
        "bootstrap_iterations": {
          "default": 0,
          "minimum": 0,
          "title": "Bootstrap Iterations",
          "type": "integer"
        },
        "ci_lower": {
          "anyOf": [
            {
              "pattern": "^-?(0|1)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Lower"
        },
        "ci_upper": {
          "anyOf": [
            {
              "pattern": "^-?(0|1)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ci Upper"
        },
        "cluster_count": {
          "minimum": 0,
          "title": "Cluster Count",
          "type": "integer"
        },
        "confirmatory_interval_uses_planned_icc": {
          "default": true,
          "title": "Confirmatory Interval Uses Planned Icc",
          "type": "boolean"
        },
        "confirmatory_use": {
          "default": "disabled",
          "enum": [
            "disabled",
            "eligible_large_cluster_threshold",
            "eligible_external_review"
          ],
          "title": "Confirmatory Use",
          "type": "string"
        },
        "endpoint_id": {
          "minLength": 1,
          "title": "Endpoint Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "observation_count": {
          "minimum": 0,
          "title": "Observation Count",
          "type": "integer"
        },
        "observed_intraclass_correlation": {
          "anyOf": [
            {
              "pattern": "^-?(0|1)\\.[0-9]{6}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Intraclass Correlation"
        },
        "planned_intraclass_correlation": {
          "pattern": "^0\\.[0-9]{6}$",
          "title": "Planned Intraclass Correlation",
          "type": "string"
        },
        "schema_version": {
          "const": "0.2.0",
          "default": "0.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "uncertainty_method": {
          "default": "not_evaluated",
          "enum": [
            "cluster_bootstrap_percentile",
            "not_evaluated"
          ],
          "title": "Uncertainty Method",
          "type": "string"
        }
      },
      "required": [
        "endpoint_id",
        "label",
        "cluster_count",
        "observation_count",
        "planned_intraclass_correlation"
      ],
      "title": "ClusterCorrelationSummary",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "const": "finding",
          "default": "finding",
          "title": "Artifact Kind",
